{
    "name": "veltphp/cli",
    "description": "Official CLI and code generators for the Velt framework.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Velt\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Velt\\Cli\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/velt"
    ],
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
