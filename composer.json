{
    "name": "velt/cli",
    "description": "Official CLI and code generators for the Velt framework.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "velt/database": "dev-main",
        "velt/kernel": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Velt\\Cli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Velt\\Cli\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/velt"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../velt-database",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../veltphp-kernel/packages/kernel",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../velt-ui",
            "options": {
                "symlink": true
            }
        }
    ],
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
