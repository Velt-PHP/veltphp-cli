#!/usr/bin/env php
<?php

/**
 * Point d'entrée principal de la CLI Velt
 * 
 * Ce fichier est exécuté quand l'utilisateur tape une commande comme:
 *   php bin/velt list
 *   php bin/velt make:controller User
 * 
 * Flux:
 *   1. Charge l'autoload de Composer (ou crée un fallback)
 *   2. Récupère les arguments du terminal via $_SERVER['argv']
 *   3. Crée l'application CLI via ApplicationFactory
 *   4. Lance la bonne commande
 */

declare(strict_types=1);

$autoload = __DIR__ . '/../vendor/autoload.php';

if (is_file($autoload)) {
    require $autoload;
} else {
    spl_autoload_register(static function (string $class): void {
        $prefix = 'Velt\\Cli\\';

        if (! str_starts_with($class, $prefix)) {
            return;
        }

        $relativeClass = substr($class, strlen($prefix));
        $file = __DIR__ . '/../src/' . str_replace('\\', '/', $relativeClass) . '.php';

        if (is_file($file)) {
            require $file;
        }
    });
}

exit(Velt\Cli\ApplicationFactory::create()->run($_SERVER['argv'] ?? []));
